# ---- LLM Providers ----
ANTHROPIC_API_KEY=sk-ant-replace-me
OPENAI_API_KEY=                       # Optional fallback

# ---- LangSmith Tracing ----
LANGSMITH_API_KEY=lsv2_pt_replace-me
LANGSMITH_PROJECT=trialmatch-ai-dev
LANGSMITH_TRACING=true

# ---- Application Settings ----
LOG_LEVEL=INFO
MODEL_NAME=claude-sonnet-4-6
MAX_TRIALS_PER_QUERY=25
ENABLE_HITL=true

# ---- External APIs ----
CLINICALTRIALS_BASE_URL=https://clinicaltrials.gov/api/v2
PUBMED_API_KEY=                       # Optional, raises rate limit
